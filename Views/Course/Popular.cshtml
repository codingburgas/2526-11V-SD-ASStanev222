@{
    ViewData["Title"] = "Popular Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Popular Courses</h1>
    <div>
        <span class="badge bg-info fs-6">Top @(ViewBag.TopCount ?? 10) Courses</span>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var course in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-primary">
                    <div class="card-header bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-light text-dark">Popular</span>
                            <small><i class="bi bi-people"></i> @course.EnrolledStudentCount students</small>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@course.Title</h5>
                        <p class="card-text flex-grow-1">@course.Description</p>
                        <div class="mt-auto">
                            <small class="text-muted d-block mb-2">
                                <i class="bi bi-person"></i> @course.CreatedByUserName
                            </small>
                            <div class="d-flex gap-2">
                                <a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id" class="btn btn-primary btn-sm">View Details</a>
                                <a asp-controller="Lesson" asp-action="Index" asp-route-courseId="@course.Id" class="btn btn-outline-secondary btn-sm">Lessons</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-trophy display-1 text-muted"></i>
        <h3 class="mt-3">No popular courses yet</h3>
        <p class="text-muted">Courses will appear here as students enroll.</p>
        <a asp-controller="Course" asp-action="Index" class="btn btn-primary">Browse All Courses</a>
    </div>
}

<div class="mt-4">
    <a asp-controller="Course" asp-action="Index" class="btn btn-outline-primary">View All Courses</a>
    <a asp-controller="Statistics" asp-action="Index" class="btn btn-outline-info ms-2">View Statistics</a>
</div>