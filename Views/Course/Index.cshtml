@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Courses</h1>
    <a asp-controller="Course" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create New Course
    </a>
</div>

@if (Model != null && Model.Any())
{
    var courses = Model;
    <div class="row">
        @foreach (var course in courses)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@course.Title</h5>
                        <p class="card-text flex-grow-1">@course.Description</p>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="text-muted">
                                    <i class="bi bi-calendar"></i> @course.CreatedAt.ToString("MMM dd, yyyy")
                                </small>
                                <small class="text-muted">
                                    <i class="bi bi-people"></i> @course.EnrolledStudentCount students
                                </small>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id" class="btn btn-outline-primary btn-sm">View Details</a>
                                <a asp-controller="Lesson" asp-action="Index" asp-route-courseId="@course.Id" class="btn btn-outline-secondary btn-sm">Lessons</a>
                                <a asp-controller="Test" asp-action="Index" asp-route-courseId="@course.Id" class="btn btn-outline-success btn-sm">Tests</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-book display-1 text-muted"></i>
        <h3 class="mt-3">No courses available</h3>
        <p class="text-muted">Be the first to create a course!</p>
        <a asp-controller="Course" asp-action="Create" class="btn btn-primary">Create First Course</a>
    </div>
}

<div class="mt-4">
    <a asp-controller="Course" asp-action="Popular" class="btn btn-outline-info">View Popular Courses</a>
</div>