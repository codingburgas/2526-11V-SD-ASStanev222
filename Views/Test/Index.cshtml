@{
    ViewData["Title"] = "Tests - " + ViewBag.Course?.Title;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Tests</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Details" asp-route-id="@ViewBag.Course?.Id">@ViewBag.Course?.Title</a></li>
                <li class="breadcrumb-item active">Tests</li>
            </ol>
        </nav>
    </div>
    <a asp-controller="Test" asp-action="Create" asp-route-courseId="@ViewBag.Course?.Id" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Test
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var test in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">@test.Title</h5>
                        <div>
                            <a asp-controller="Test" asp-action="Edit" asp-route-id="@test.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <a asp-controller="Test" asp-action="Delete" asp-route-id="@test.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <p class="card-text">@test.Description</p>
                        <div class="mt-auto">
                            <div class="row mb-2">
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="bi bi-check-circle"></i> Passing: @test.PassingScore%
                                    </small>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="bi bi-question-circle"></i> @test.Questions?.Count questions
                                    </small>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-controller="Test" asp-action="Details" asp-route-id="@test.Id" class="btn btn-outline-primary btn-sm">View Details</a>
                                <a asp-controller="Test" asp-action="Take" asp-route-id="@test.Id" class="btn btn-success btn-sm">
                                    <i class="bi bi-play-circle"></i> Take Test
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-check-circle display-1 text-muted"></i>
        <h3 class="mt-3">No tests in this course</h3>
        <p class="text-muted">Start by adding the first test.</p>
        <a asp-controller="Test" asp-action="Create" asp-route-courseId="@ViewBag.Course?.Id" class="btn btn-primary">Add First Test</a>
    </div>
}

<div class="mt-4">
    <a asp-controller="Course" asp-action="Details" asp-route-id="@ViewBag.Course?.Id" class="btn btn-outline-secondary">Back to Course</a>
    <a asp-controller="Lesson" asp-action="Index" asp-route-courseId="@ViewBag.Course?.Id" class="btn btn-outline-info ms-2">View Lessons</a>
</div>