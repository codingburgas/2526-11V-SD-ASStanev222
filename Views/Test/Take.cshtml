@model ProjectLMS.Models.ViewModels.TestViewModel
@{
    ViewData["Title"] = "Take Test - " + Model.Title;
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId">@Model.CourseName</a></li>
                <li class="breadcrumb-item"><a asp-controller="Test" asp-action="Index" asp-route-courseId="@Model.CourseId">Tests</a></li>
                <li class="breadcrumb-item active">@Model.Title</li>
            </ol>
        </nav>

        <div class="card">
            <div class="card-header bg-primary text-white">
                <h1 class="h4 mb-0">
                    <i class="bi bi-play-circle"></i> @Model.Title
                </h1>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <strong>Test Information:</strong>
                    <ul class="mb-0 mt-2">
                        <li>@Model.Questions?.Count questions</li>
                        <li>Passing score: @Model.PassingScore%</li>
                        <li>Grade scale: 2-6 (Excellent to Poor)</li>
                    </ul>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mb-4">
                        <h5>Test Description</h5>
                        <p>@Model.Description</p>
                    </div>
                }

                <form method="post" action="/Test/Submit/@Model.Id">
                    @Html.AntiForgeryToken()

                    @if (Model.Questions != null && Model.Questions.Any())
                    {
                        for (int i = 0; i < Model.Questions.Count; i++)
                        {
                            var question = Model.Questions[i];
                            <div class="card mb-3">
                                <div class="card-header">
                                    <h6 class="mb-0">
                                        Question @(i + 1) of @Model.Questions.Count
                                        <small class="text-muted ms-2">(@question.Points point(s))</small>
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="mb-3">@question.QuestionText</p>

                                    @if (question.Answers != null && question.Answers.Any())
                                    {
                                        <div class="ms-3">
                                            @for (int j = 0; j < question.Answers.Count; j++)
                                            {
                                                var answer = question.Answers[j];
                                                <div class="form-check mb-2">
                                                    <input class="form-check-input" type="radio"
                                                           name="answers[@question.Id]" id="answer_@question.Id@j"
                                                           value="@answer.Id">
                                                    <label class="form-check-label" for="answer_@question.Id@j">
                                                        @answer.AnswerText
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="d-flex gap-2 justify-content-center">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Submit Test
                            </button>
                            <a asp-controller="Test" asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-outline-secondary btn-lg">Cancel</a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-exclamation-triangle text-warning display-4"></i>
                            <h4 class="mt-3">Test Not Available</h4>
                            <p>This test has no questions yet.</p>
                            <a asp-controller="Test" asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-primary">Back to Tests</a>
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>