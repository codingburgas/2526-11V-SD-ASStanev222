@model ProjectLMS.Models.ViewModels.TestResultViewModel
@{
    ViewData["Title"] = "Test Results";
    var headerColor = Model.IsPassed ? "#28a745" : "#dc3545";
    var resultText = Model.IsPassed ? "PASSED" : "FAILED";
    var resultClass = Model.IsPassed ? "text-success" : "text-danger";
    var headerIcon = Model.IsPassed ? "bi-trophy" : "bi-x-circle";
    var headerText = Model.IsPassed ? "Test Passed!" : "Test Failed";
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card">
            <div class="card-header text-center text-white" style="background-color: @headerColor">
                <h1 class="h4 mb-0">
                    <i class="bi @headerIcon"></i> @headerText
                </h1>
            </div>
            <div class="card-body text-center">
                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="border rounded p-3">
                            <h3 class="text-primary">@Model.Score%</h3>
                            <small class="text-muted">Score</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3">
                            <h3 class="text-info">@Model.Grade</h3>
                            <small class="text-muted">Grade (2-6 scale)</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3">
                            <h3 class="@resultClass">
                                @resultText
                            </h3>
                            <small class="text-muted">Result</small>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info">
                    <strong>Feedback:</strong> @Model.Feedback
                </div>

                <div class="mb-4">
                    <small class="text-muted">
                        Test completed on @Model.AttemptedAt.ToString("MMMM dd, yyyy 'at' HH:mm")
                    </small>
                </div>

                @if (ViewBag.StudentAnswers != null)
                {
                    <div class="text-start">
                        <h5>Your Answers:</h5>
                        @foreach (var answer in ViewBag.StudentAnswers as IEnumerable<ProjectLMS.Models.ViewModels.StudentAnswerViewModel> ?? new List<ProjectLMS.Models.ViewModels.StudentAnswerViewModel>())
                        {
                            <div class="card mb-2">
                                <div class="card-body">
                                    <p class="mb-1"><strong>@answer.QuestionText</strong></p>
                                    <p class="mb-1">Your answer: @answer.SelectedAnswerText</p>
                                    <small class="@(answer.IsCorrect ? "text-success" : "text-danger")">
                                        @(answer.IsCorrect ? "✓ Correct" : "✗ Incorrect")
                                    </small>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="d-flex gap-2 justify-content-center mt-4">
                    <a asp-controller="Test" asp-action="Index" asp-route-courseId="@Model.TestId" class="btn btn-primary">Back to Tests</a>
                    <a asp-controller="Statistics" asp-action="Student" asp-route-id="2" class="btn btn-outline-info">View My Progress</a>
                </div>
            </div>
        </div>
    </div>
</div>