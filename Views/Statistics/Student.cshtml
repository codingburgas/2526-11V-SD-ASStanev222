@model ProjectLMS.Models.ViewModels.StudentProgressViewModel
@{
    ViewData["Title"] = "Student Progress";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Student Progress</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Statistics" asp-action="Index">Statistics</a></li>
                <li class="breadcrumb-item active">Student Progress</li>
            </ol>
        </nav>
    </div>
    <div>
        <span class="badge bg-success">Student ID: @Model?.UserId</span>
    </div>
</div>

@if (Model != null)
{
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-primary">@Model.EnrolledCoursesCount</h3>
                    <small class="text-muted">Enrolled Courses</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-success">@Model.CompletedLessonsCount</h3>
                    <small class="text-muted">Completed Lessons</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-info">@Model.CompletedTestsCount</h3>
                    <small class="text-muted">Tests Taken</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-warning">@Model.OverallAverageGrade.ToString("F1")</h3>
                    <small class="text-muted">Average Grade</small>
                </div>
            </div>
        </div>
    </div>

    @if (Model.CourseProgress != null && Model.CourseProgress.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Course Progress</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (var course in Model.CourseProgress)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card h-100">
                                <div class="card-header">
                                    <h6 class="mb-0">@course.CourseName</h6>
                                </div>
                                <div class="card-body">
                                    <div class="row text-center">
                                        <div class="col-6">
                                            <h5 class="text-primary">@course.CompletedLessons/@course.TotalLessons</h5>
                                            <small class="text-muted">Lessons</small>
                                        </div>
                                        <div class="col-6">
                                            <h5 class="text-success">@course.CompletedTests/@course.TotalTests</h5>
                                            <small class="text-muted">Tests</small>
                                        </div>
                                    </div>
                                    <div class="mt-2">
                                        <small class="text-muted">Average Grade: @course.AverageGrade.ToString("F1")</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Recent Test Results</h5>
        </div>
        <div class="card-body">
            @if (Model.CourseProgress != null && Model.CourseProgress.Any(c => c.TestResults.Any()))
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Course</th>
                                <th>Test</th>
                                <th>Score</th>
                                <th>Grade</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var course in Model.CourseProgress)
                            {
                                if (course.TestResults != null)
                                {
                                    foreach (var result in course.TestResults.OrderByDescending(r => r.AttemptedAt).Take(5))
                                    {
                                        <tr>
                                            <td>@course.CourseName</td>
                                            <td>@result.TestName</td>
                                            <td>@result.Score%</td>
                                            <td>
                                                <span class="badge bg-secondary">@result.Grade</span>
                                            </td>
                                            <td>
                                                @if (result.IsPassed)
                                                {
                                                    <span class="badge bg-success">Passed</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Failed</span>
                                                }
                                            </td>
                                            <td>@result.AttemptedAt.ToString("MMM dd, yyyy")</td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-clipboard-x text-muted display-4"></i>
                    <h5 class="mt-3">No test results yet</h5>
                    <p class="text-muted">Take some tests to see your progress here.</p>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> Student progress data not found.
    </div>
}

<div class="mt-4">
    <a asp-controller="Statistics" asp-action="Index" class="btn btn-outline-secondary">Back to Statistics</a>
    <a asp-controller="Course" asp-action="Index" class="btn btn-outline-primary ms-2">Browse Courses</a>
</div>