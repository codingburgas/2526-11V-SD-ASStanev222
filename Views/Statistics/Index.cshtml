@{
    ViewData["Title"] = "Statistics Dashboard";
}

<!-- Header Section -->
<section class="bg-info text-white py-4 mb-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-5 fw-bold mb-2">
                    <i class="bi bi-graph-up me-3"></i>Statistics Dashboard
                </h1>
                <p class="lead mb-0">Comprehensive analytics and insights for your learning platform</p>
            </div>
            <div class="col-md-4 text-center">
                <i class="bi bi-bar-chart-line display-1 text-white-50"></i>
            </div>
        </div>
    </div>
</section>

<div class="container">
    @if (Model != null && Model.Any())
    {
        <!-- Course Statistics Cards -->
        <div class="row mb-5">
            <div class="col-12">
                <h3 class="fw-bold mb-4">
                    <i class="bi bi-book me-2 text-primary"></i>Course Analytics
                </h3>
            </div>
            @foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h6 class="mb-0 fw-bold text-primary">@course.Title</h6>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <p class="card-text text-muted small mb-3">@course.Description</p>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <div class="text-center">
                                        <h4 class="text-success mb-1">@course.EnrolledStudentCount</h4>
                                        <small class="text-muted">Students</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="text-center">
                                        <h4 class="text-info mb-1">@course.CreatedByUserName</h4>
                                        <small class="text-muted">Teacher</small>
                                    </div>
                                </div>
                            </div>
                            <a asp-controller="Statistics" asp-action="Course" asp-route-id="@course.Id" class="btn btn-primary mt-auto">
                                <i class="bi bi-bar-chart me-2"></i>View Statistics
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Quick Access Cards -->
    <div class="row mb-5">
        <div class="col-12">
            <h3 class="fw-bold mb-4">
                <i class="bi bi-speedometer2 me-2 text-success"></i>Quick Access
            </h3>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="bg-success bg-opacity-10 rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-person-lines-fill text-success fs-4"></i>
                    </div>
                    <h5 class="card-title fw-bold">Student Progress</h5>
                    <p class="card-text text-muted">View individual student progress and performance metrics.</p>
                    <a asp-controller="Statistics" asp-action="Student" asp-route-id="2" class="btn btn-success">
                        <i class="bi bi-person-check me-2"></i>My Progress
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="bg-warning bg-opacity-10 rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-trophy text-warning fs-4"></i>
                    </div>
                    <h5 class="card-title fw-bold">Popular Courses</h5>
                    <p class="card-text text-muted">Discover which courses have the highest enrollment rates.</p>
                    <a asp-controller="Statistics" asp-action="PopularCourses" class="btn btn-warning">
                        <i class="bi bi-star me-2"></i>View Rankings
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Features Overview -->
    <div class="card border-0 shadow-sm bg-light">
        <div class="card-body p-4">
            <h4 class="card-title fw-bold mb-3">
                <i class="bi bi-info-circle-fill text-info me-2"></i>Available Analytics
            </h4>
            <div class="row">
                <div class="col-md-6">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>Course enrollment statistics
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>Student progress tracking
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>Test performance analytics
                        </li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>Grade distribution reports
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>Popular courses ranking
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>Completion rate analysis
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>