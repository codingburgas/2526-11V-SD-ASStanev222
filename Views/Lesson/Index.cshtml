@{
    ViewData["Title"] = "Lessons - " + ViewBag.Course?.Title;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Lessons</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Details" asp-route-id="@ViewBag.Course?.Id">@ViewBag.Course?.Title</a></li>
                <li class="breadcrumb-item active">Lessons</li>
            </ol>
        </nav>
    </div>
    <a asp-controller="Lesson" asp-action="Create" asp-route-courseId="@ViewBag.Course?.Id" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Lesson
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var lesson in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">@lesson.Title</h5>
                        <div>
                            <a asp-controller="Lesson" asp-action="Edit" asp-route-id="@lesson.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <a asp-controller="Lesson" asp-action="Delete" asp-route-id="@lesson.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="card-text">@lesson.Content</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                Order: @lesson.Order
                            </small>
                            <a asp-controller="Lesson" asp-action="Details" asp-route-id="@lesson.Id" class="btn btn-outline-primary btn-sm">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-journal-text display-1 text-muted"></i>
        <h3 class="mt-3">No lessons in this course</h3>
        <p class="text-muted">Start by adding the first lesson.</p>
        <a asp-controller="Lesson" asp-action="Create" asp-route-courseId="@ViewBag.Course?.Id" class="btn btn-primary">Add First Lesson</a>
    </div>
}

<div class="mt-4">
    <a asp-controller="Course" asp-action="Details" asp-route-id="@ViewBag.Course?.Id" class="btn btn-outline-secondary">Back to Course</a>
    <a asp-controller="Test" asp-action="Index" asp-route-courseId="@ViewBag.Course?.Id" class="btn btn-outline-success ms-2">View Tests</a>
</div>