@model ProjectLMS.Models.ViewModels.LessonViewModel
@{
    ViewData["Title"] = "Edit Lesson - " + Model.Title;
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId">@Model.CourseName</a></li>
                <li class="breadcrumb-item"><a asp-controller="Lesson" asp-action="Index" asp-route-courseId="@Model.CourseId">Lessons</a></li>
                <li class="breadcrumb-item active">Edit @Model.Title</li>
            </ol>
        </nav>

        <div class="card">
            <div class="card-header">
                <h1 class="h4 mb-0">Edit Lesson</h1>
            </div>
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="CourseId" value="@Model.CourseId" />

                    <div class="mb-3">
                        <label for="Title" class="form-label">Lesson Title</label>
                        <input type="text" class="form-control" id="Title" name="Title"
                               value="@Model.Title" required maxlength="200">
                        @Html.ValidationMessage("Title", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label for="Content" class="form-label">Lesson Content</label>
                        <textarea class="form-control" id="Content" name="Content"
                                  rows="8" maxlength="2000">@Model.Content</textarea>
                        @Html.ValidationMessage("Content", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label for="Order" class="form-label">Order</label>
                        <input type="number" class="form-control" id="Order" name="Order"
                               value="@Model.Order" min="1">
                        @Html.ValidationMessage("Order", new { @class = "text-danger" })
                        <div class="form-text">The order in which this lesson appears in the course.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Save Changes
                        </button>
                        <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>