@{
    ViewData["Title"] = "About";
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card">
            <div class="card-header">
                <h1 class="h3 mb-0">About ProjectLMS</h1>
            </div>
            <div class="card-body">
                <p class="lead">ProjectLMS is a comprehensive Learning Management System built with modern web technologies.</p>

                <h4>Features</h4>
                <ul>
                    <li><strong>Course Management:</strong> Create, edit, and organize courses with structured lessons</li>
                    <li><strong>Automated Testing:</strong> Multiple-choice tests with automatic grading on a 2-6 scale</li>
                    <li><strong>Student Progress Tracking:</strong> Detailed statistics and performance analytics</li>
                    <li><strong>Role-based Security:</strong> Support for Teachers, Students, and Administrators</li>
                    <li><strong>Responsive Design:</strong> Works seamlessly on desktop and mobile devices</li>
                </ul>

                <h4>Technology Stack</h4>
                <ul>
                    <li><strong>Backend:</strong> ASP.NET Core MVC 10.0 (Preview)</li>
                    <li><strong>Database:</strong> Entity Framework Core with SQL Server LocalDB</li>
                    <li><strong>Frontend:</strong> Bootstrap 5, Razor Views</li>
                    <li><strong>Architecture:</strong> Layered architecture with dependency injection</li>
                </ul>

                <h4>Architecture</h4>
                <p>The system follows a clean layered architecture:</p>
                <ul>
                    <li><strong>Web Layer:</strong> MVC Controllers and Razor Views</li>
                    <li><strong>Services Layer:</strong> Business logic and data processing</li>
                    <li><strong>Data Layer:</strong> Entity Framework Core and database operations</li>
                </ul>

                <div class="alert alert-info">
                    <strong>Project Status:</strong> This LMS is designed for educational purposes and demonstrates
                    professional ASP.NET Core development practices including Code-First migrations,
                    dependency injection, and clean architecture patterns.
                </div>
            </div>
        </div>
    </div>
</div>