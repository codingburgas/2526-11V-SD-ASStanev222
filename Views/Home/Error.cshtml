@{
    ViewData["Title"] = "Error";
}

<div class="row">
    <div class="col-lg-6 mx-auto">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h1 class="h4 mb-0">
                    <i class="bi bi-exclamation-triangle"></i> Error
                </h1>
            </div>
            <div class="card-body text-center">
                <i class="bi bi-x-circle text-danger display-1"></i>
                <h2 class="mt-3">Oops! Something went wrong.</h2>
                <p class="text-muted">An error occurred while processing your request.</p>
                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Go Home</a>
                    <button onclick="history.back()" class="btn btn-outline-secondary ms-2">Go Back</button>
                </div>
            </div>
        </div>
    </div>
</div>